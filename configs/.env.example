# ─────────────────────────────────────────────────
# Speed Layer — Environment Variables
# Copy this file:  cp .env.example .env
# ─────────────────────────────────────────────────

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
RAW_TOPIC=raw_events
DLQ_TOPIC=raw_events_dlq

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_SECONDS=7200

CHECKPOINT_DIR=/tmp/speed_layer_checkpoints
TRIGGER_SECONDS=10

# ─────────────────────────────────────────────────
# Crawler / Producer — Throughput Control
# ─────────────────────────────────────────────────
# Extra delay (seconds) after each Kafka produce (on top of crawler delay)
PRODUCER_DELAY_SECONDS=0
